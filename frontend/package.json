    "axios": "^1.7.0",
    "dotenv": "^17.4.2",
    "postcss": "^8.5.14",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.3",
    "react-scripts": "5.0.1"
  },
  "scripts": {
